# Apache .htaccess cho CodeIgniter 3
# Đặt file này tại: c:\xampp\htdocs\php\cuoi ki\.htaccess

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /php/cuoi%20ki/

    # Nếu request là file/folder thực sự → không rewrite
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Còn lại → chuyển về index.php của CodeIgniter
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>
